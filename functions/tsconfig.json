{
  "compilerOptions": {
    "module":           "commonjs",
    "target":           "es2020",
    "lib":              ["es2020"],
    "outDir":           "lib",
    "rootDir":          "src",
    "strict":           true,
    "noImplicitReturns": true,
    "noUnusedLocals":   false,
    "esModuleInterop":  true,
    "resolveJsonModule": true,
    "sourceMap":        true,
    "skipLibCheck":     true
  },
  "compileOnSave": true,
  "include": ["src"]
}
