# .env.example
# Copy this file to .env and fill in your actual values for local development.
# On Render, set these as environment variables in the dashboard.

# Flask
SECRET_KEY=change-this-to-a-random-string

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# TMDb
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_BASE=https://image.tmdb.org/t/p

# Firebase — local dev: point to your credentials file
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json
FIREBASE_WEB_API_KEY=your_firebase_web_api_key_here

# Firebase — Render: paste the entire contents of firebase-credentials.json as a single-line JSON string.
# Leave blank for local dev (file-based credentials will be used instead).
FIREBASE_CREDENTIALS_JSON=

# Server (Render sets PORT automatically; leave blank for local dev)
PORT=5000
